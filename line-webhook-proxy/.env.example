# Local port for development
PORT=8787

# LINE Developers Console -> Messaging API channel -> Basic settings
LINE_CHANNEL_SECRET=

# LINE Developers Console -> Messaging API channel -> Messaging API
LINE_CHANNEL_ACCESS_TOKEN=

# Optional. Leave blank if webhook events already include source.userId
LINE_DEFAULT_USER_ID=

# Your deployed Google Apps Script Web App /exec URL
GAS_BASE_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
